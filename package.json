{
  "name": "memoerial-project",
  "private": true,
  "version": "2.1.3",
  "type": "module",
  "main": "electron-main.js",
  "homepage": "https://github.com/AlfreeFenix/memorial-project",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:full": "concurrently \"vite\" \"node server/index.js\"",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "predeploy": "npm run build",
    "resume:clear": "node npm/npm-resume-clear.js",
    "electron:dev": "npm run build && electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.tuapp.electron",
    "files": [
      "dist/**/*",
      "electron-main.js",
      "!node_modules"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@fortawesome/fontawesome-free": "^6.4.0",
    "@popperjs/core": "^2.11.7",
    "bootstrap": "^5.2.3",
    "chart.js": "^4.4.8",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "emailjs": "^4.0.3",
    "express": "^4.19.2",
    "gh-pages": "^6.3.0",
    "html2canvas": "^1.4.1",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "primeicons": "^7.0.0",
    "qrcode": "^1.5.4",
    "swiper": "^10.0.4",
    "vue": "^3.2.47",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.2.1",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "sass": "^1.94.2",
    "vite": "^6.2.5"
  }
}
